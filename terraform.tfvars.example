# ==============================================================================
# Terraform Variables Example
# ==============================================================================
# このファイルをコピーして terraform.tfvars を作成してください
# cp terraform.tfvars.example terraform.tfvars

# General Settings
aws_region   = "ap-northeast-1"
project_name = "white-board"
environment  = "dev"

# Network Settings
vpc_cidr           = "10.0.0.0/20"
availability_zones = ["ap-northeast-1a", "ap-northeast-1c"]

# NAT Gateway Settings (コスト最適化)
enable_nat_gateway = true
single_nat_gateway = true  # false にすると各AZにNAT Gatewayを配置（高可用性）

# DNS / Route53
# 例:
# domain_name = "example.com"
# frontend_subdomain = "white-board"
# backend_public_subdomain "api.white-board"

# CDN / CloudFront
# 必須: CloudFrontのオリジンにするフロントエンドALBのDNS名
# frontend_alb_dns_name = "alb-xxxxxxxx.ap-northeast-1.elb.amazonaws.com" # 同一スタックで作る場合は不要
# 任意:
# enable_cdn = true
# cloudfront_price_class = "PriceClass_200"

# Frontend ECS
# frontend_container_image  = "nginx:alpine"
# Tag of the ECR image to deploy (example: "latest" or "v1.2.3")
# frontend_image_tag        = "latest"
# frontend_container_port   = 3000
# frontend_desired_count    = 2
# frontend_task_cpu         = 256
# frontend_task_memory      = 512
# frontend_health_check_path = "/"

# Backend ECS
# backend_container_port   = 4000
# backend_image_tag        = "latest"
# backend_desired_count    = 2
# backend_task_cpu         = 256
# backend_task_memory      = 512
# backend_health_check_path = "/health"

# RDS PostgreSQL
# rds_engine_version       = "17"
# rds_instance_class       = "db.t4g.micro"
# rds_allocated_storage    = 20
# rds_max_allocated_storage = 100
# rds_multi_az             = false
# rds_db_name              = "whiteboard"
# rds_username             = "dev"
# rds_backup_retention     = 7
# rds_maintenance_window   = "Mon:20:00-Mon:21:00"
# rds_backup_window        = "19:00-20:00"

# DynamoDB
# dynamodb_table_name       = "drawings"
# dynamodb_billing_mode     = "PAY_PER_REQUEST" # or PROVISIONED
# dynamodb_ttl_attribute    = "ttl"             # empty to disable
# dynamodb_enable_stream    = false
# dynamodb_stream_view_type = "NEW_AND_OLD_IMAGES"

# Redis
# redis_node_type                 = "cache.t4g.micro"
# redis_engine_version            = "7.1"
# redis_replicas_per_node_group   = 0

